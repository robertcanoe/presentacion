{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Angular: ng serve",
      "type": "shell",
      "command": "npm start",
      "options": { "cwd": "${workspaceFolder}/angular" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": { "regexp": "Changes detected" },
          "endsPattern": { "regexp": "bundle generation (complete|failed)" }
        }
      },
      "group": "build",
      "presentation": { "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "React: vite dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/react" },
      "isBackground": true,
      "problemMatcher": [],
      "group": "build",
      "presentation": { "panel": "dedicated", "reveal": "always" }
    }
  ]
}
